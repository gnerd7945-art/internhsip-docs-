GstElement* bus = gst_pipeline_get_bus(GST_PIPELINE(pipeline)); // bus points to pipeline's message bus. 

gst_bus_add_watch(bus,bus_call,loop) // whenever message arrives in 'bus', call bus_call function in GMainLoop so whnever message arrives GmainLoop wakes up and call bus_call ,loop= which main loop should run callback. 
** Basically it connect bus_call function to loop:-
1) The loop says to the Operating System: "Wake me up only if something happens on the Bus."
2) When a message arrives, the OS wakes the loop, and the loop calls your bus_call

 gboolean bus_call(GstBus *bus, GstMessage *msg, gpointer data) {
    switch (GST_MESSAGE_TYPE(msg)) {  //could have done msg->type , msg points to structre not just an int or char which could be used in switch thus need to go inside the stuct and get integer value 
        case GST_MESSAGE_EOS:
            g_print("End of stream\n");
            g_main_loop_quit((GMainLoop *)data);
            break;
        case GST_MESSAGE_ERROR: {
            gchar *debug;  // declared pointer to save ram, otherwise for every message whole structure will be allocated even if not called 
            GError *error;
            gst_message_parse_error(msg, &error, &debug); // takes data from msg and puts it in error,debug ( now memory for that created)
            g_printerr("Error: %s\n", error->message);
            g_error_free(error); // go to address the pointer is pointing to and clean that structure memory) 
            g_free(debug);
            g_main_loop_quit((GMainLoop *)data);
            break;
        }
        default:
            break;
    }
    return TRUE; // Continue listening
}
